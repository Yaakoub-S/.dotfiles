# defaults
alias ls="ls --color=auto"
alias ll="ls -alF"
alias grep="grep --color=auto"

# nvim
alias v="nvim"
alias vi="nvim"
alias vim="nvim"

# git
alias g="git"
alias gs="git status"
alias ga="git add"
alias gc="git commit -m"
alias gp="git push"
alias gl="git log --oneline --graph --decorate"
alias gd="git diff"

# dotfiles
alias gitdf='git --git-dir=$DOTFILES --work-tree=$HOME'
